{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CORTEX",
  "version": "0.1.0",
  "identifier": "com.cortex.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "CORTEX",
        "width": 1600,
        "height": 1000,
        "minWidth": 1200,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI5OUJFQ0M0RTNBREI0QjEKUldTeHRLM2p4T3lidWFEZlNyTGd4OHkwOURxZXNYOXMyL3F1UG10SnM3bmpmY0dtRENkaXhuTnYK",
      "endpoints": [
        "https://github.com/Frixxy93/Cortex/releases/latest/download/latest.json"
      ]
    }
  }
}
